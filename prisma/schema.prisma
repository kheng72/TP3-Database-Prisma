model Checkin {
  id         Int       @id @default(autoincrement())
  StudentId String    @map("student_id") @db.VarChar(8)
  roomCode   String    @map("room_code") @db.VarChar(10)
  checkIn    DateTime? @map("check_in")
  checkOut   DateTime? @map("check_out")

  student User @relation(fields: [StudentId], references: [StudentId])
  room    Room    @relation(fields: [roomCode], references: [roomCode])

  @@index([StudentId])
  @@index([roomCode])
  @@index([checkIn])

  @@map("checkin")
}

